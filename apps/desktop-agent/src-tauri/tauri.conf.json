{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Bridge Agent",
  "version": "0.1.89",
  "identifier": "ai.openai.codex.bridge.agent",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "settings",
        "title": "Codex Bridge",
        "width": 620,
        "height": 650,
        "minWidth": 520,
        "minHeight": 560,
        "visible": false,
        "decorations": false,
        "resizable": true,
        "center": true,
        "backgroundColor": "#151515"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
